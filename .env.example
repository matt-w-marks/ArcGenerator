# Root .env.example — copy to .env and fill in real values before running docker compose

# PostgreSQL
POSTGRES_PASSWORD=change-me

# Auth Service
AUTH_DATABASE_URL=postgresql://postgres:change-me@db:5432/arcgenerator_auth
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
JWT_SECRET=change-me-min-32-chars-long-secret
JWT_REFRESH_SECRET=change-me-min-32-chars-long-refresh-secret

# Metrics + Export Services
METRICS_DATABASE_URL=postgresql+psycopg://postgres:change-me@db:5432/arcgenerator

# Shared factory logging (all services)
LOGGING_DATABASE_URL=postgresql+psycopg://postgres:change-me@db:5432/factory_logs
