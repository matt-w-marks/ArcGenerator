{
  "name": "roadmap-auth",
  "version": "0.1.0",
  "description": "RoadMap Dashboard Auth Service",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "bcryptjs": "2.4.3",
    "express": "4.22.1",
    "express-rate-limit": "7.3.1",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "pg": "8.12.0",
    "pg-hstore": "2.3.4",
    "sequelize": "6.37.8",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "jest": "29.7.0",
    "supertest": "7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/**/*.js"],
    "coverageThreshold": {
      "src/services/authService.js": {
        "lines": 100,
        "branches": 100,
        "functions": 100,
        "statements": 100
      }
    }
  }
}
